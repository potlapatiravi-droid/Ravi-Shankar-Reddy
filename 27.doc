mysql> SELECT e.*
    -> FROM employee e
    -> JOIN (
    -> SELECT dept,
    -> MAX(salary) AS max_salary
    -> FROM employee
    -> GROUP BY dept
    -> ) d
    -> ON e.dept=d.dept
    -> AND e.salary=d.max_salary;
